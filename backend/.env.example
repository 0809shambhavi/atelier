# ── Required ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Images (Unsplash — free, instant) ────────────
UNSPLASH_KEY=your-unsplash-access-key

# ── Weather (free, instant) ───────────────────────
OPENWEATHER_KEY=your-openweather-key

# ── Shopping (RapidAPI Real-Time Product Search) ──
RAPIDAPI_KEY=your-rapidapi-key

# ── Trends (optional) ────────────────────────────
TAVILY_KEY=your-tavily-key

# ── Supabase (auth + database + saves) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Frontend URL (for CORS) ───────────────────────
FRONTEND_URL=http://localhost:5173

# ── Pinterest (optional, apply at developers.pinterest.com) ──
PINTEREST_TOKEN=
